# AumOS Event Bus — Local Development Environment
# Copy this file to .env and fill in values before running locally.

# ---------------------------------------------------------------------------
# Database (required)
# ---------------------------------------------------------------------------
AUMOS_DATABASE__URL=postgresql+asyncpg://aumos:aumos_dev@localhost:5432/aumos
AUMOS_DATABASE__POOL_SIZE=10
AUMOS_DATABASE__MAX_OVERFLOW=20

# ---------------------------------------------------------------------------
# Kafka broker
# ---------------------------------------------------------------------------
AUMOS_KAFKA__BROKERS=localhost:9092
AUMOS_KAFKA__CONSUMER_GROUP_ID=aumos-event-bus

# ---------------------------------------------------------------------------
# Confluent Schema Registry
# ---------------------------------------------------------------------------
AUMOS_KAFKA__SCHEMA_REGISTRY_URL=http://localhost:8081
AUMOS_EVENTBUS_SCHEMA_REGISTRY_URL=http://localhost:8081
AUMOS_EVENTBUS_SCHEMA_REGISTRY_USERNAME=
AUMOS_EVENTBUS_SCHEMA_REGISTRY_PASSWORD=
AUMOS_EVENTBUS_SCHEMA_COMPATIBILITY_DEFAULT=BACKWARD

# ---------------------------------------------------------------------------
# Keycloak / Auth (required for protected endpoints)
# ---------------------------------------------------------------------------
AUMOS_KEYCLOAK__URL=http://localhost:8080
AUMOS_KEYCLOAK__REALM=aumos
AUMOS_KEYCLOAK__CLIENT_ID=aumos-event-bus
AUMOS_KEYCLOAK__CLIENT_SECRET=dev-secret

# ---------------------------------------------------------------------------
# Redis (optional — for caching)
# ---------------------------------------------------------------------------
AUMOS_REDIS__URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Event Bus specific settings
# ---------------------------------------------------------------------------
AUMOS_EVENTBUS_DLQ_MAX_RETRIES=5
AUMOS_EVENTBUS_DLQ_INITIAL_BACKOFF_MS=1000
AUMOS_EVENTBUS_DLQ_MAX_BACKOFF_MS=60000
AUMOS_EVENTBUS_DLQ_BACKOFF_MULTIPLIER=2.0

AUMOS_EVENTBUS_TOPIC_DEFAULT_REPLICATION_FACTOR=1
AUMOS_EVENTBUS_TOPIC_DEFAULT_MIN_ISR=1
AUMOS_EVENTBUS_TOPIC_CREATION_TIMEOUT_MS=30000

AUMOS_EVENTBUS_TENANT_PARTITIONER_SEED=42
AUMOS_EVENTBUS_MAX_TENANTS_PER_PARTITION=10

AUMOS_EVENTBUS_AUTO_CREATE_STANDARD_TOPICS=true
AUMOS_EVENTBUS_MANAGEMENT_API_ENABLED=true

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
AUMOS_ENVIRONMENT=development
AUMOS_LOG_LEVEL=INFO
AUMOS_OTEL__ENDPOINT=http://localhost:4317
AUMOS_OTEL__ENABLED=false
